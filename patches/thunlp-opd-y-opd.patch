diff --git a/verl/verl/trainer/ppo/y_opd_controller.py b/verl/verl/trainer/ppo/y_opd_controller.py
new file mode 100644
index 0000000..ad98c68
--- /dev/null
+++ b/verl/verl/trainer/ppo/y_opd_controller.py
@@ -0,0 +1,333 @@
+import math
+from dataclasses import dataclass
+from typing import Any
+
+import torch
+
+
+def _cfg_get(cfg: Any, key: str, default: Any) -> Any:
+    if cfg is None:
+        return default
+    if isinstance(cfg, dict):
+        return cfg.get(key, default)
+    return cfg.get(key, default)
+
+
+@dataclass
+class YOPDUpdateResult:
+    metrics: dict[str, float]
+    updated: bool
+
+
+class GlobalYOPDController:
+    """Global sequence-level temperature controller for Y-OPD.
+
+    The controller owns only training-time rollout policy state. It never changes
+    the student loss; it scores finished rollouts using existing OPD
+    student/teacher tensors and updates a global distribution over temperatures.
+    """
+
+    def __init__(self, config: Any):
+        self.enabled = bool(_cfg_get(config, "enabled", False))
+        self.temperatures = [
+            float(x)
+            for x in _cfg_get(
+                config,
+                "temperatures",
+                [0.5, 0.6, 0.7, 0.8, 0.9, 1.0, 1.1, 1.2, 1.3, 1.4, 1.5, 1.6, 1.7],
+            )
+        ]
+        if len(self.temperatures) == 0:
+            raise ValueError("Y-OPD requires at least one temperature.")
+
+        self.top_p = float(_cfg_get(config, "top_p", 0.95))
+        self.policy_top_p = float(_cfg_get(config, "policy_top_p", 0.7))
+        self.warmup_temperature = float(_cfg_get(config, "warmup_temperature", 1.0))
+        self.eta = float(_cfg_get(config, "eta", 0.05))
+        self.epsilon = float(_cfg_get(config, "epsilon", 0.05))
+        self.rho = float(_cfg_get(config, "rho", 0.05))
+        self.b_weight = float(_cfg_get(config, "b_weight", 5.0))
+        self.mass_threshold = float(_cfg_get(config, "mass_threshold", 0.5))
+        self.warmup_steps = int(_cfg_get(config, "warmup_steps", 10))
+        self.threshold_ema = float(_cfg_get(config, "threshold_ema", 0.95))
+        self.baseline_ema = float(_cfg_get(config, "baseline_ema", 0.95))
+        self.adv_clip = float(_cfg_get(config, "adv_clip", 5.0))
+        self.logit_clip = float(_cfg_get(config, "logit_clip", 5.0))
+        self.credit_temperature = float(_cfg_get(config, "credit_temperature", 1.0))
+        self.credit_normalizer = str(_cfg_get(config, "credit_normalizer", "sparsemax"))
+        self.seed = int(_cfg_get(config, "seed", 0))
+
+        self.logits = torch.zeros(len(self.temperatures), dtype=torch.float32)
+        self.baseline_y = 0.0
+        self.baseline_initialized = False
+        self.thresholds: dict[str, float] = {}
+
+    def policy_probs(self) -> torch.Tensor:
+        probs = torch.softmax(self.logits, dim=-1)
+        if self.epsilon > 0:
+            uniform = torch.full_like(probs, 1.0 / probs.numel())
+            probs = (1.0 - self.epsilon) * probs + self.epsilon * uniform
+        return probs
+
+    def snapshot(self, global_step: int) -> dict[str, Any]:
+        probs = self.policy_probs()
+        return {
+            "enabled": self.enabled,
+            "temperatures": list(self.temperatures),
+            "probs": probs.detach().cpu().tolist(),
+            "top_p": self.top_p,
+            "policy_top_p": self.policy_top_p,
+            "forced_temperature": self.warmup_temperature if int(global_step) <= self.warmup_steps else None,
+            "seed": self.seed + int(global_step) * 1000003,
+        }
+
+    def state_dict(self) -> dict[str, Any]:
+        return {
+            "enabled": self.enabled,
+            "temperatures": list(self.temperatures),
+            "top_p": self.top_p,
+            "policy_top_p": self.policy_top_p,
+            "warmup_temperature": self.warmup_temperature,
+            "eta": self.eta,
+            "epsilon": self.epsilon,
+            "rho": self.rho,
+            "b_weight": self.b_weight,
+            "mass_threshold": self.mass_threshold,
+            "warmup_steps": self.warmup_steps,
+            "threshold_ema": self.threshold_ema,
+            "baseline_ema": self.baseline_ema,
+            "adv_clip": self.adv_clip,
+            "logit_clip": self.logit_clip,
+            "credit_temperature": self.credit_temperature,
+            "credit_normalizer": self.credit_normalizer,
+            "seed": self.seed,
+            "logits": self.logits,
+            "baseline_y": self.baseline_y,
+            "baseline_initialized": self.baseline_initialized,
+            "thresholds": dict(self.thresholds),
+        }
+
+    def load_state_dict(self, state: dict[str, Any]) -> None:
+        if list(state["temperatures"]) != self.temperatures:
+            raise ValueError(
+                f"Cannot load Y-OPD controller with temperatures {state['temperatures']} "
+                f"into controller with temperatures {self.temperatures}."
+            )
+        self.logits = state["logits"].detach().cpu().float()
+        self.baseline_y = float(state.get("baseline_y", 0.0))
+        self.baseline_initialized = bool(state.get("baseline_initialized", False))
+        self.thresholds = {k: float(v) for k, v in state.get("thresholds", {}).items()}
+
+    def save(self, path: str) -> None:
+        torch.save(self.state_dict(), path)
+
+    def load(self, path: str) -> None:
+        self.load_state_dict(torch.load(path, map_location="cpu", weights_only=False))
+
+    @torch.no_grad()
+    def update_from_batch(self, batch, global_step: int) -> YOPDUpdateResult:
+        metrics: dict[str, float] = {"y_opd/enabled": float(self.enabled)}
+        if not self.enabled:
+            return YOPDUpdateResult(metrics=metrics, updated=False)
+
+        required = [
+            "response_mask",
+            "responses",
+            "old_log_probs",
+            "entropys",
+            "student_top_k_ids",
+            "student_top_k_log_probs",
+            "teacher_on_student_log_probs",
+            "y_opd_temp_id",
+        ]
+        missing = [key for key in required if key not in batch.batch.keys()]
+        if missing:
+            metrics["y_opd/skipped_missing_tensors"] = 1.0
+            return YOPDUpdateResult(metrics=metrics, updated=False)
+
+        response_mask = batch.batch["response_mask"].bool()
+        responses = batch.batch["responses"]
+        old_log_probs = batch.batch["old_log_probs"].float()
+        entropys = batch.batch["entropys"].float()
+        student_top_k_ids = batch.batch["student_top_k_ids"]
+        student_top_k_log_probs = batch.batch["student_top_k_log_probs"].float()
+        teacher_on_student_log_probs = batch.batch["teacher_on_student_log_probs"].float()
+        temp_id = batch.batch["y_opd_temp_id"].long()
+
+        finite = torch.isfinite(old_log_probs) & torch.isfinite(entropys)
+        valid = response_mask & finite
+        if valid.sum().item() == 0:
+            metrics["y_opd/skipped_no_valid_tokens"] = 1.0
+            return YOPDUpdateResult(metrics=metrics, updated=False)
+
+        safe_student_logp = student_top_k_log_probs.masked_fill(~torch.isfinite(student_top_k_log_probs), -80.0)
+        safe_teacher_logp = teacher_on_student_log_probs.masked_fill(
+            ~torch.isfinite(teacher_on_student_log_probs), -80.0
+        )
+        student_p = torch.softmax(safe_student_logp, dim=-1)
+        disagreement = torch.sum(student_p * (safe_student_logp - safe_teacher_logp), dim=-1)
+        teacher_mass_on_student = torch.exp(safe_teacher_logp).sum(dim=-1).clamp(max=1.0)
+
+        batch_thresholds = self._batch_thresholds(entropys, disagreement, valid)
+        if not self.thresholds:
+            self.thresholds = batch_thresholds
+
+        active_update = int(global_step) > self.warmup_steps
+        thresholds = self.thresholds
+        a_token = entropys > thresholds["entropy_high"]
+        b_token = (
+            (entropys < thresholds["entropy_low"])
+            & (disagreement > thresholds["disagreement_high"])
+            & (teacher_mass_on_student > self.mass_threshold)
+        )
+        a_token = a_token & valid
+        b_token = b_token & valid
+
+        token_count = valid.sum(dim=-1).clamp_min(1)
+        a_rate = a_token.float().sum(dim=-1) / token_count
+        b_rate = b_token.float().sum(dim=-1) / token_count
+        y = a_rate + self.b_weight * b_rate
+
+        valid_seq = (valid.sum(dim=-1) > 0) & (temp_id >= 0) & (temp_id < len(self.temperatures))
+        if valid_seq.sum().item() == 0:
+            self._update_thresholds(batch_thresholds)
+            metrics["y_opd/skipped_no_valid_sequences"] = 1.0
+            return YOPDUpdateResult(metrics=metrics, updated=False)
+
+        y_valid = y[valid_seq]
+        temp_id_valid = temp_id[valid_seq]
+        mean_y = y_valid.mean().detach()
+        if not self.baseline_initialized:
+            self.baseline_y = float(mean_y.item())
+            self.baseline_initialized = True
+
+        baseline = torch.tensor(self.baseline_y, dtype=y_valid.dtype, device=y_valid.device)
+        advantage = (y_valid - baseline).clamp(min=-self.adv_clip, max=self.adv_clip)
+
+        update_applied = False
+        if active_update and valid_seq.sum().item() > 0:
+            credit = self._temperature_credit(
+                old_log_probs=old_log_probs[valid_seq],
+                responses=responses[valid_seq],
+                student_top_k_ids=student_top_k_ids[valid_seq],
+                student_top_k_log_probs=safe_student_logp[valid_seq],
+                weights=(self.rho + a_token.float() + self.b_weight * b_token.float())[valid_seq],
+                valid=valid[valid_seq],
+            )
+            pi = self.policy_probs().to(device=credit.device, dtype=credit.dtype)
+            delta = self.eta * (advantage.unsqueeze(-1) * (credit - pi.unsqueeze(0))).mean(dim=0)
+            self.logits += delta.detach().cpu()
+            self.logits -= self.logits.mean()
+            self.logits.clamp_(min=-self.logit_clip, max=self.logit_clip)
+            update_applied = True
+
+            metrics["y_opd/credit_entropy"] = float(self._entropy(credit.mean(dim=0)).detach().cpu().item())
+            metrics["y_opd/credit_max"] = float(credit.max(dim=-1).values.mean().detach().cpu().item())
+
+        self.baseline_y = self.baseline_ema * self.baseline_y + (1.0 - self.baseline_ema) * float(mean_y.item())
+        self._update_thresholds(batch_thresholds)
+
+        probs = self.policy_probs()
+        metrics.update(
+            {
+                "y_opd/update_active": float(update_applied),
+                "y_opd/warmup_active": float(not active_update),
+                "y_opd/num_valid_sequences": float(valid_seq.sum().item()),
+                "y_opd/valid_token_ratio": float(valid.float().mean().detach().cpu().item()),
+                "y_opd/mean_A_rate": float(a_rate[valid_seq].mean().detach().cpu().item()),
+                "y_opd/mean_B_rate": float(b_rate[valid_seq].mean().detach().cpu().item()),
+                "y_opd/mean_Y": float(mean_y.detach().cpu().item()),
+                "y_opd/baseline_Y": float(self.baseline_y),
+                "y_opd/adv_mean": float(advantage.mean().detach().cpu().item()),
+                "y_opd/adv_abs_mean": float(advantage.abs().mean().detach().cpu().item()),
+                "y_opd/policy_entropy": float(self._entropy(probs).detach().cpu().item()),
+                "y_opd/logit_norm": float(self.logits.norm().item()),
+                "y_opd/threshold_entropy_high": float(self.thresholds["entropy_high"]),
+                "y_opd/threshold_entropy_low": float(self.thresholds["entropy_low"]),
+                "y_opd/threshold_disagreement_high": float(self.thresholds["disagreement_high"]),
+            }
+        )
+        for i, temp in enumerate(self.temperatures):
+            temp_mask = temp_id_valid == i
+            metrics[f"y_opd/prob_T_{temp:g}"] = float(probs[i].item())
+            metrics[f"y_opd/usage_T_{temp:g}"] = float(temp_mask.float().mean().detach().cpu().item())
+            if temp_mask.any():
+                metrics[f"y_opd/mean_Y_T_{temp:g}"] = float(y_valid[temp_mask].mean().detach().cpu().item())
+
+        return YOPDUpdateResult(metrics=metrics, updated=update_applied)
+
+    def _batch_thresholds(self, entropys: torch.Tensor, disagreement: torch.Tensor, valid: torch.Tensor) -> dict[str, float]:
+        ent = entropys[valid]
+        dis = disagreement[valid]
+        if ent.numel() == 0:
+            return dict(self.thresholds) if self.thresholds else {
+                "entropy_high": 0.0,
+                "entropy_low": 0.0,
+                "disagreement_high": 0.0,
+            }
+        return {
+            "entropy_high": float(torch.quantile(ent.float(), 0.70).detach().cpu().item()),
+            "entropy_low": float(torch.quantile(ent.float(), 0.40).detach().cpu().item()),
+            "disagreement_high": float(torch.quantile(dis.float(), 0.75).detach().cpu().item()),
+        }
+
+    def _update_thresholds(self, batch_thresholds: dict[str, float]) -> None:
+        if not self.thresholds:
+            self.thresholds = dict(batch_thresholds)
+            return
+        for key, value in batch_thresholds.items():
+            self.thresholds[key] = self.threshold_ema * self.thresholds[key] + (1.0 - self.threshold_ema) * value
+
+    def _temperature_credit(
+        self,
+        old_log_probs: torch.Tensor,
+        responses: torch.Tensor,
+        student_top_k_ids: torch.Tensor,
+        student_top_k_log_probs: torch.Tensor,
+        weights: torch.Tensor,
+        valid: torch.Tensor,
+    ) -> torch.Tensor:
+        temp_values = torch.tensor(self.temperatures, device=old_log_probs.device, dtype=old_log_probs.dtype)
+        generated_in_topk = (student_top_k_ids == responses.unsqueeze(-1)).any(dim=-1)
+        generated_logp = old_log_probs.masked_fill(generated_in_topk, -math.inf).unsqueeze(-1)
+        support_logp = torch.cat([student_top_k_log_probs, generated_logp], dim=-1)
+
+        likelihoods = []
+        denom_weights = (weights * valid.float()).sum(dim=-1).clamp_min(1e-6)
+        for temp in temp_values:
+            support = support_logp / temp
+            denom = torch.logsumexp(support, dim=-1)
+            logp_t = old_log_probs / temp - denom
+            weighted = (weights * logp_t * valid.float()).sum(dim=-1) / denom_weights
+            likelihoods.append(weighted)
+        likelihoods = torch.stack(likelihoods, dim=-1)
+        credit_temp = max(self.credit_temperature, 1e-6)
+        scores = likelihoods / credit_temp
