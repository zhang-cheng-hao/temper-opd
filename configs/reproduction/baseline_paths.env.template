# Copy this file on the 8-GPU machine, fill the paths, then source it before
# running the reproduction commands. Do not commit the filled copy if it
# contains machine-private paths or tokens.

# Shared output roots.
export OPD_ENV_ROOT="/mmu_mllm_hdd/zhangchenghao05/envs"
