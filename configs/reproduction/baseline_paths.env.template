export NNODES=1
# Optional: JSON list/string or comma-separated parquet paths. Defaults to AIME25/AMC23/AIME24.
# export THUNLP_TEST_DATASET='["/path/to/AIME25/test.parquet","/path/to/AMC23/test.parquet","/path/to/AIME24/test.parquet"]'

# TA-OPD.
export TA_OPD_CONDA_PREFIX="${OPD_ENV_ROOT}/ta-opd"
export TA_OPD_DIR="/path/to/temper-opd/baselines/ta-opd"
