export THUNLP_TEST_DATA_DIR="/path/to/temper-opd/baselines/thunlp-opd/datasets/test_data"
export THUNLP_PROJECT_PATH="${REPRO_OUTPUT_ROOT}/thunlp_opd/checkpoint"
